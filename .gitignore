# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Ignore specific files
pornhub_cookies.txt
*_cookies.txt
*.ua
video_downloader.log

# Ignore all log files
*.log

# Ignore folders
logs/
downloaded_videos/
downloads/
build/
dist/

# PyInstaller output (see build_windows.ps1)
release/SHUCK3R.exe
release/SHUCK3RWebView.exe

# Optional Cursor ui-ux-pro-max skill bundle (install under .shared/ — see .shared/README.md)
.shared/ui-ux-pro-max/

# graphify intermediate pipeline artifacts (keep GRAPH_REPORT.md, graph.json, graph.html)
graphify-out/cache/
graphify-out/.graphify_*

# Browser "Save Page" dumps (allow curated ph-*.html + README to be tracked/added)
website-code/*
!website-code/README.md
!website-code/ph-*.html

# Chrome/Edge saved-page companion folders and renamed downloads (anywhere in repo)
*_files/
*.js.download

# SHUCK3R / HamsterScraper per-user data if copied into repo (HAMSTER_USER_DATA override)
HamsterScraper/
browser_profiles/

# VS Code — keep shared tasks.json; ignore machine-local settings
.vscode/*
!.vscode/tasks.json

# Cursor / JetBrains / OS junk
.cursor/
.idea/
Thumbs.db
Desktop.ini
.DS_Store

# Local secrets / env
.env
.env.*

# Scratch scripts at repo root
_tmp_*.py
